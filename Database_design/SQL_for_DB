CREATE TABLE public.applications (
  id integer NOT NULL DEFAULT nextval('applications_id_seq'::regclass),
  job_id integer,
  student_user_id integer,
  status character varying DEFAULT 'APPLIED'::character varying,
  created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT applications_pkey PRIMARY KEY (id),
  CONSTRAINT applications_job_id_fkey FOREIGN KEY (job_id) REFERENCES public.jobs(id),
  CONSTRAINT applications_student_user_id_fkey FOREIGN KEY (student_user_id) REFERENCES public.users(id)
);
CREATE TABLE public.jobs (
  id integer NOT NULL DEFAULT nextval('jobs_id_seq'::regclass),
  recruiter_id integer,
  title character varying NOT NULL,
  description text NOT NULL,
  location character varying,
  salary integer,
  job_type character varying,
  created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
  stipend_or_ctc character varying,
  minimum_cgpa double precision,
  skills_required text,
  application_deadline timestamp without time zone,
  status character varying DEFAULT 'OPEN'::character varying,
  is_active boolean DEFAULT false,
  CONSTRAINT jobs_pkey PRIMARY KEY (id),
  CONSTRAINT jobs_recruiter_id_fkey FOREIGN KEY (recruiter_id) REFERENCES public.users(id)
);
CREATE TABLE public.recruiter_details (
  id integer NOT NULL DEFAULT nextval('recruiter_details_id_seq'::regclass),
  user_id integer UNIQUE,
  company_name character varying,
  designation character varying,
  phone character varying,
  company_description text,
  company_website character varying,
  CONSTRAINT recruiter_details_pkey PRIMARY KEY (id),
  CONSTRAINT recruiter_details_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.users(id)
);
CREATE TABLE public.student_details (
  id integer NOT NULL DEFAULT nextval('student_details_id_seq'::regclass),
  user_id integer UNIQUE,
  department character varying,
  graduation_year integer,
  cgpa double precision,
  course character varying,
  rollno integer,
  phone character varying,
  resume_url text,
  CONSTRAINT student_details_pkey PRIMARY KEY (id),
  CONSTRAINT student_details_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.users(id)
);
CREATE TABLE public.users (
  id integer NOT NULL DEFAULT nextval('users_id_seq'::regclass),
  name character varying,
  email character varying NOT NULL UNIQUE,
  password_hash text NOT NULL,
  role character varying CHECK (role::text = ANY (ARRAY['STUDENT'::character varying, 'RECRUITER'::character varying, 'ADMIN'::character varying]::text[])),
  created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
  status character varying DEFAULT 'PENDING'::character varying,
  is_active boolean DEFAULT false,
  refresh_token text,
  CONSTRAINT users_pkey PRIMARY KEY (id)
);